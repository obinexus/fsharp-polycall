{
  "name": "@obinexusltd/fsharp-polycall",
  "version": "1.0.0",
  "description": "F#/.NET P/Invoke source binding for libpolycall 1.5",
  "main": "index.js",
  "type": "commonjs",
  "files": [
    "index.js",
    "src/",
    "c_src/",
    "include/",
    "generated/",
    "examples/",
    "tests/",
    "scripts/",
    "Makefile",
    "fsharp-polycallrc",
    "polycall-binding.json",
    "README.md",
    "TODO.md",
    "LICENSE"
  ],
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
