<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>OBINexus.FSharpPolycall</PackageId>
    <Version>1.0.0</Version>
    <Authors>Nnamdi Michael Okpala</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Description>Thin F# P/Invoke binding for libpolycall 1.5.</Description>
    <RepositoryUrl>https://github.com/obinexus/fsharp-polycall</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Polycall.fs" />
  </ItemGroup>
</Project>
